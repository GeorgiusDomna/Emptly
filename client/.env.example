# Скопируйте в client/.env и при необходимости измените значения.
# После правок перезапустите: npm run dev
#
# ─── Режим A: обычная разработка (backend: npm run dev) ───
# Оставьте VITE_WS_URL и VITE_HEALTH_URL пустыми — URL соберутся автоматически.
# Если BACKEND_PORT не задан, клиент использует same-origin /ws и /health (удобно для reverse proxy).

# BACKEND_PORT=5001

# ─── Режим B: backend с TLS (backend: npm run certs:dev && npm run dev:secure) ───
# Раскомментируйте две строки ниже и закомментируйте/очистите авто-режим, если нужен явный wss.

# VITE_WS_URL=wss://localhost:5001/ws
# VITE_HEALTH_URL=https://localhost:5001/health

# ─── Опционально (сейчас в коде не используются) ───

# VITE_APP_ENV=development
# VITE_SENTRY_DSN=
