{
    "compilerOptions": {
      "outDir": "./dist/",
      "noImplicitAny": true,
      "module": "ESNext",
      "target": "es2017",
      "jsx": "react-jsx",
      "allowJs": true,
      "moduleResolution": "node",
      "esModuleInterop": true,
      "allowSyntheticDefaultImports": true,
      "baseUrl": "./",
      "paths": {
        "@/*": ["src/*"]
      }
    },
    "ts-node": {
      "compilerOptions": {
        "module": "CommonJS",
        "baseUrl": ".",
        "paths": {
          "@/*": ["./*"]
        }
      }
    }
}