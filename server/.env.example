# Скопируйте в server/.env и при необходимости измените значения.
# После правок перезапустите backend.

# ─── Обязательно для локальной разработки ───

NODE_ENV=development
PORT=5001

# Origin фронтенда (webpack dev server). Несколько origin — через запятую.
# В production CORS_ORIGIN обязателен, иначе сервер не стартует.
# На Render/static+API: укажите точный URL, с которого открывается SPA (не URL backend).
# Пример: CORS_ORIGIN=https://your-frontend.onrender.com,https://your-frontend.com
CORS_ORIGIN=http://localhost:3000

# ─── Режим A: WebSocket без TLS (npm run dev) ───
# TLS_* не задавайте — сервер поднимется на http:// и ws://

# ─── Режим B: HTTPS / WSS (npm run certs:dev, затем npm run dev:secure) ───
# Раскомментируйте обе строки. Сертификаты: server/certs/ после npm run certs:dev

# TLS_CERT_PATH=./certs/dev-cert.pem
# TLS_KEY_PATH=./certs/dev-key.pem

# Цепочка CA, если нужна (обычно пусто для dev)
# TLS_CA_PATH=

# ─── Лимиты (можно не менять) ───

ROOM_IDLE_TTL_MS=1800000
MAX_MESSAGE_BYTES=4096
HEARTBEAT_INTERVAL_MS=30000
RATE_LIMIT_WINDOW_MS=10000
RATE_LIMIT_EVENTS_PER_WINDOW=120

# Уровень структурированных логов: debug | info | warn | error
LOG_LEVEL=info

# ─── Не используется текущим server/src (только legacy) ───

# LOG_LEVEL=info
# MONGO_URL=
