# В этом репозитории нет корневого .env для запуска.
#
# Скопируйте примеры в рабочие файлы:
#   cp server/.env.example server/.env
#   cp client/.env.example client/.env
#
# Быстрый старт (WS):
#   server: npm run dev
#   client: npm run dev
#   client/.env — достаточно BACKEND_PORT=5001
#
# WSS локально:
#   server: npm run certs:dev && npm run dev:secure
#   client/.env — раскомментировать VITE_WS_URL и VITE_HEALTH_URL (см. client/.env.example)
#   браузер: один раз открыть https://localhost:5001/health и принять сертификат
